# Telegram Bot Token — get from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here

# PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://booking_user:booking_pass@localhost:5432/booking_db

# Admin Telegram ID — the Telegram user ID of the business owner
# Send /start to @userinfobot on Telegram to find your ID
ADMIN_TELEGRAM_ID=123456789

# Business name shown in bot messages
BUSINESS_NAME=Demo Barbershop

# Timezone for the business (used for slot generation)
TIMEZONE=Asia/Tashkent
